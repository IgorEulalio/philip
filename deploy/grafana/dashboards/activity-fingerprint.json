{
  "uid": "philip-activity-fingerprint",
  "title": "Philip — CI/CD Security Monitor",
  "description": "Job execution history, scores, verdicts, and baseline state",
  "tags": ["philip"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "repository",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(philip_events_ingested_total, repository)",
        "query": "label_values(philip_events_ingested_total, repository)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "job_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(philip_jobs_analyzed_total{repository=~\"$repository\"}, job_name)",
        "query": "label_values(philip_jobs_analyzed_total{repository=~\"$repository\"}, job_name)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Analyzed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Clean",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=~\"clean|benign\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Suspicious",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=\"suspicious\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Critical",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=\"critical\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 10,
      "title": "Baseline Status per Repository",
      "description": "Shows whether each repository/job is in learning mode or active detection mode",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name) (philip_baseline_status{repository=~\"$repository\", job_name=~\"$job_name\", status=\"active\"}) or max by(repository, job_name) (philip_baseline_status{repository=~\"$repository\", job_name=~\"$job_name\", status=\"learning\"} * 0)",
          "format": "table",
          "instant": true,
          "refId": "Mode"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name) (philip_baseline_jobs_observed{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "JobsObserved"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name) (philip_baseline_process_profiles{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Processes"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name) (philip_baseline_network_profiles{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Network"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name) (philip_baseline_file_access_profiles{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Files"
        }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "repository": "Repository",
              "job_name": "Job",
              "Value #Mode": "Mode",
              "Value #JobsObserved": "Jobs Observed",
              "Value #Processes": "Process Profiles",
              "Value #Network": "Network Profiles",
              "Value #Files": "File Profiles"
            },
            "indexByName": {
              "Repository": 0,
              "Job": 1,
              "Mode": 2,
              "Jobs Observed": 3,
              "Process Profiles": 4,
              "Network Profiles": 5,
              "File Profiles": 6
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Mode" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "LEARNING", "color": "yellow", "index": 0 } } },
                  { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "green", "index": 1 } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Repository", "desc": false }]
      }
    },
    {
      "id": 5,
      "title": "Job Executions",
      "description": "Each job execution with score, verdict, and event details",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name, job_id, run_id) (philip_job_exec_timestamp_seconds{repository=~\"$repository\", job_name=~\"$job_name\"}) * 1000",
          "format": "table",
          "instant": true,
          "refId": "Timestamp"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name, job_id, run_id) (philip_job_exec_score{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Score"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name, job_id, run_id) (philip_job_exec_verdict{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Verdict"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name, job_id, run_id) (philip_job_exec_event_count{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Events"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name, job_id, run_id) (philip_job_exec_deviation_count{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Deviations"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by(repository, job_name, job_id, run_id) (philip_job_exec_severity{repository=~\"$repository\", job_name=~\"$job_name\"})",
          "format": "table",
          "instant": true,
          "refId": "Severity"
        }
      ],
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "indexByName": {
              "job_id": 0,
              "run_id": 1,
              "repository": 2,
              "job_name": 3,
              "Value #Timestamp": 4,
              "Value #Score": 5,
              "Value #Verdict": 6,
              "Value #Events": 7,
              "Value #Deviations": 8,
              "Value #Severity": 9
            },
            "renameByName": {
              "job_id": "Job ID",
              "run_id": "Run ID",
              "repository": "Repository",
              "job_name": "Job",
              "Value #Timestamp": "Timestamp",
              "Value #Score": "Score",
              "Value #Verdict": "Verdict",
              "Value #Events": "Events",
              "Value #Deviations": "Deviations",
              "Value #Severity": "Severity"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [{ "field": "Timestamp", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Job ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View on GitHub",
                    "url": "https://github.com/${__data.fields.Repository}/actions/runs/${__data.fields[\"Run ID\"]}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Run ID" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Timestamp" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Score" },
            "properties": [
              { "id": "decimals", "value": 2 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.3 },
                    { "color": "orange", "value": 0.6 },
                    { "color": "red", "value": 0.85 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Verdict" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "color": "green", "text": "CLEAN" } } },
                  { "type": "value", "options": { "1": { "color": "green", "text": "BENIGN" } } },
                  { "type": "value", "options": { "2": { "color": "orange", "text": "SUSPICIOUS" } } },
                  { "type": "value", "options": { "3": { "color": "red", "text": "CRITICAL" } } },
                  { "type": "value", "options": { "4": { "color": "yellow", "text": "LOW CONFIDENCE" } } },
                  { "type": "value", "options": { "5": { "color": "blue", "text": "LEARNING" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "color": "text", "text": "-" } } },
                  { "type": "value", "options": { "1": { "color": "green", "text": "LOW" } } },
                  { "type": "value", "options": { "2": { "color": "yellow", "text": "MEDIUM" } } },
                  { "type": "value", "options": { "3": { "color": "orange", "text": "HIGH" } } },
                  { "type": "value", "options": { "4": { "color": "red", "text": "CRITICAL" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deviations" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Job Score Over Time",
      "description": "Max deviation score per execution over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_score{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "legendFormat": "{{job_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "points", "pointSize": 8 },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 7,
      "title": "Deviation Rate by Type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(type)(rate(philip_deviations_total{repository=~\"$repository\", job_name=~\"$job_name\"}[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "new_process" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "new_network" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suspicious_args" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
          },
          {
            "matcher": { "id": "byName", "options": "unexpected_parent" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "sensitive_path" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Verdicts Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(verdict)(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 40 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "clean" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "benign" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suspicious" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "learning" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "Score Distribution",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(le)(rate(philip_deviation_score_bucket{repository=~\"$repository\", job_name=~\"$job_name\"}[1h]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "color": { "scheme": "Oranges" },
        "yAxis": { "unit": "short" }
      }
    }
  ],
  "schemaVersion": 39
}
