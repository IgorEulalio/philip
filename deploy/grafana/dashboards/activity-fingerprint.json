{
  "uid": "philip-activity-fingerprint",
  "title": "Philip — CI/CD Security Monitor",
  "description": "Job execution history, scores, verdicts, and baseline state",
  "tags": ["philip"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "repository",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(philip_events_ingested_total, repository)",
        "query": "label_values(philip_events_ingested_total, repository)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "job_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(philip_jobs_analyzed_total{repository=~\"$repository\"}, job_name)",
        "query": "label_values(philip_jobs_analyzed_total{repository=~\"$repository\"}, job_name)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Analyzed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Clean",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=~\"clean|benign\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Suspicious",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=\"suspicious\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Critical",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=\"critical\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 10,
      "title": "Baseline Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_baseline_jobs_observed{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "legendFormat": "{{job_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "options": { "graphMode": "none" }
    },
    {
      "id": 11,
      "title": "Baseline",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_baseline_status{repository=~\"$repository\", job_name=~\"$job_name\"} == 1",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "active", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "yellow", "value": null }]
          }
        }
      },
      "options": { "graphMode": "none" }
    },
    {
      "id": 5,
      "title": "Job Executions",
      "description": "Each job execution with score, verdict, and event details",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_timestamp_seconds{repository=~\"$repository\", job_name=~\"$job_name\"} * 1000",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_score{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_verdict{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_event_count{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_deviation_count{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_severity{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "F"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(job_id|repository|job_name|Value.*)$"
            }
          }
        },
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "job_id": 0,
              "repository": 1,
              "job_name": 2,
              "Value #A": 3,
              "Value #B": 4,
              "Value #C": 5,
              "Value #D": 6,
              "Value #E": 7,
              "Value #F": 8
            },
            "renameByName": {
              "job_id": "Job ID",
              "repository": "Repository",
              "job_name": "Job",
              "Value #A": "Timestamp",
              "Value #B": "Score",
              "Value #C": "Verdict",
              "Value #D": "Events",
              "Value #E": "Deviations",
              "Value #F": "Severity"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [{ "field": "Timestamp", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Timestamp" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Score" },
            "properties": [
              { "id": "decimals", "value": 2 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.3 },
                    { "color": "orange", "value": 0.6 },
                    { "color": "red", "value": 0.85 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Verdict" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "color": "green", "text": "CLEAN" } } },
                  { "type": "value", "options": { "1": { "color": "green", "text": "BENIGN" } } },
                  { "type": "value", "options": { "2": { "color": "orange", "text": "SUSPICIOUS" } } },
                  { "type": "value", "options": { "3": { "color": "red", "text": "CRITICAL" } } },
                  { "type": "value", "options": { "4": { "color": "yellow", "text": "LOW CONFIDENCE" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "color": "text", "text": "-" } } },
                  { "type": "value", "options": { "1": { "color": "green", "text": "LOW" } } },
                  { "type": "value", "options": { "2": { "color": "yellow", "text": "MEDIUM" } } },
                  { "type": "value", "options": { "3": { "color": "orange", "text": "HIGH" } } },
                  { "type": "value", "options": { "4": { "color": "red", "text": "CRITICAL" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deviations" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Job Score Over Time",
      "description": "Max deviation score per execution over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_exec_score{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "legendFormat": "{{job_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "points", "pointSize": 8 },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 7,
      "title": "Deviation Rate by Type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(type)(rate(philip_deviations_total{repository=~\"$repository\", job_name=~\"$job_name\"}[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "new_process" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "new_network" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suspicious_args" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
          },
          {
            "matcher": { "id": "byName", "options": "unexpected_parent" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "sensitive_path" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Verdicts Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(verdict)(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 40 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "clean" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "benign" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suspicious" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "Score Distribution",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(le)(rate(philip_deviation_score_bucket{repository=~\"$repository\", job_name=~\"$job_name\"}[1h]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "color": { "scheme": "Oranges" },
        "yAxis": { "unit": "short" }
      }
    }
  ],
  "schemaVersion": 39
}
