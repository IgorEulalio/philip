{
  "uid": "philip-activity-fingerprint",
  "title": "Philip — Activity Fingerprint",
  "description": "Per-repo/job activity overview with execution history and baseline state",
  "tags": ["philip"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "repository",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(philip_events_ingested_total, repository)",
        "query": "label_values(philip_events_ingested_total, repository)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "job_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(philip_jobs_analyzed_total{repository=~\"$repository\"}, job_name)",
        "query": "label_values(philip_jobs_analyzed_total{repository=~\"$repository\"}, job_name)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Analyzed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Clean",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=~\"clean|benign\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Suspicious",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=\"suspicious\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Critical",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\", verdict=\"critical\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Job Executions",
      "description": "Latest state of each monitored job",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_last_timestamp_seconds{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_last_verdict{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_last_event_count{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_last_deviation_count{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_job_last_severity{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_baseline_status{repository=~\"$repository\", job_name=~\"$job_name\"} == 1",
          "format": "table",
          "instant": true,
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "philip_baseline_jobs_observed{repository=~\"$repository\", job_name=~\"$job_name\"}",
          "format": "table",
          "instant": true,
          "refId": "G"
        }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "repository": "Repository",
              "job_name": "Job",
              "Value #A": "Last Run",
              "Value #B": "Verdict",
              "Value #C": "Events",
              "Value #D": "Deviations",
              "Value #E": "Severity",
              "Value #F": "Baseline",
              "Value #G": "Jobs Observed",
              "status": "Baseline Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last Run" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Verdict" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "color": "green", "text": "clean" } } },
                  { "type": "value", "options": { "1": { "color": "green", "text": "benign" } } },
                  { "type": "value", "options": { "2": { "color": "orange", "text": "suspicious" } } },
                  { "type": "value", "options": { "3": { "color": "red", "text": "critical" } } },
                  { "type": "value", "options": { "4": { "color": "yellow", "text": "low confidence" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "color": "text", "text": "-" } } },
                  { "type": "value", "options": { "1": { "color": "green", "text": "low" } } },
                  { "type": "value", "options": { "2": { "color": "yellow", "text": "medium" } } },
                  { "type": "value", "options": { "3": { "color": "orange", "text": "high" } } },
                  { "type": "value", "options": { "4": { "color": "red", "text": "critical" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deviations" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Activity Over Time",
      "description": "Event ingestion rate and deviation rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(repository)(rate(philip_events_ingested_total{repository=~\"$repository\"}[5m]))",
          "legendFormat": "{{repository}} — events"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(repository, job_name)(rate(philip_deviations_total{repository=~\"$repository\", job_name=~\"$job_name\"}[5m]))",
          "legendFormat": "{{repository}}/{{job_name}} — deviations"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*events" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*deviations" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Verdicts Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(verdict)(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 40 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "clean" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "benign" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suspicious" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "low_confidence" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Jobs by Verdict",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(verdict)(increase(philip_jobs_analyzed_total{repository=~\"$repository\", job_name=~\"$job_name\"}[24h]))",
          "legendFormat": "{{verdict}}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "clean" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "benign" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "semi-dark-green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suspicious" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    }
  ],
  "schemaVersion": 39
}
